---
const skills = [
    {
        icon: "☕",
        title: "Java",
        accent: "amber",
        items: [
            "Plugins de Minecraft (Paper, Spigot, Folia)",
            "APIs propias e integraciones con otros plugins",
            "GUIs interactivas y sistemas de comandos",
            "Economías, clanes, minijuegos y progresión",
            "PlaceholderAPI, LuckPerms, Vault, Adventure API",
            "Optimización de rendimiento y multithreading",
        ],
        tags: ["Java 21", "Paper", "Spigot", "Gradle", "Lombok"],
    },
    {
        icon: "🟨",
        title: "JavaScript / Node.js",
        accent: "yellow",
        items: [
            "Bots de Discord (Discord.js) con slash commands",
            "APIs REST con Express y autenticación OAuth2",
            "Automatizaciones, crons y scripts de sistema",
            "Integración con APIs externas y webhooks",
            "Scraping, procesamiento de datos y utilidades CLI",
        ],
        tags: ["Node.js", "Discord.js", "Express", "TypeScript"],
    },
    {
        icon: "🌐",
        title: "Desarrollo Web Frontend",
        accent: "purple",
        items: [
            "Sitios estáticos y SPAs con Astro y Next.js",
            "Componentes reactivos con Vue 3 y React",
            "Diseño responsive con Tailwind CSS",
            "Animaciones, transiciones y UX cuidada",
            "Integración con backends propios y CMSs",
        ],
        tags: ["Astro", "Next.js", "Vue", "React", "Tailwind"],
    },
    {
        icon: "🗄️",
        title: "Bases de Datos",
        accent: "cyan",
        items: [
            "Diseño de esquemas relacionales con MySQL",
            "Bases de datos NoSQL con MongoDB",
            "Queries optimizadas e índices eficientes",
            "Conexiones con pool y ORM/ODM",
        ],
        tags: ["MySQL", "MongoDB", "Mongoose", "JDBC"],
    },
    {
        icon: "🖥️",
        title: "Linux e Infraestructura",
        accent: "green",
        items: [
            "Configuración de VPS y servidores dedicados",
            "Instalación y gestión de Pterodactyl",
            "Proxies inversos con Nginx",
            "Backups automáticos",
            "Gestión de puertos, firewalls y redes",
        ],
        tags: ["Linux", "Nginx", "Apache", "Pterodactyl"],
    },
    {
        icon: "🐳",
        title: "Herramientas & DevOps",
        accent: "blue",
        items: [
            "Contenedores con Docker y docker-compose",
            "Control de versiones con Git y GitHub",
            "PM2 para gestión de procesos Node.js",
            "Scripts de automatización y CI básico",
        ],
        tags: ["Docker", "Git", "GitHub", "PM2"],
    },
];

const accentMap: Record<string, { border: string; hover: string; icon: string; tag: string; dot: string }> = {
    amber:  { border: "border-amber-500/25 hover:border-amber-500/50",   hover: "group-hover:text-amber-300",  icon: "bg-amber-500/10 border-amber-500/25 group-hover:border-amber-400/50",   tag: "border-amber-700/40 text-amber-400/80",  dot: "bg-amber-400" },
    yellow: { border: "border-yellow-500/25 hover:border-yellow-500/50", hover: "group-hover:text-yellow-300", icon: "bg-yellow-500/10 border-yellow-500/25 group-hover:border-yellow-400/50", tag: "border-yellow-700/40 text-yellow-400/80", dot: "bg-yellow-400" },
    purple: { border: "border-purple-500/25 hover:border-purple-500/50", hover: "group-hover:text-purple-300", icon: "bg-purple-500/10 border-purple-500/25 group-hover:border-purple-400/50", tag: "border-purple-700/40 text-purple-400/80", dot: "bg-purple-400" },
    cyan:   { border: "border-cyan-500/25 hover:border-cyan-500/50",     hover: "group-hover:text-cyan-300",   icon: "bg-cyan-500/10 border-cyan-500/25 group-hover:border-cyan-400/50",     tag: "border-cyan-700/40 text-cyan-400/80",    dot: "bg-cyan-400" },
    green:  { border: "border-emerald-500/25 hover:border-emerald-500/50", hover: "group-hover:text-emerald-300", icon: "bg-emerald-500/10 border-emerald-500/25 group-hover:border-emerald-400/50", tag: "border-emerald-700/40 text-emerald-400/80", dot: "bg-emerald-400" },
    blue:   { border: "border-sky-500/25 hover:border-sky-500/50",       hover: "group-hover:text-sky-300",    icon: "bg-sky-500/10 border-sky-500/25 group-hover:border-sky-400/50",       tag: "border-sky-700/40 text-sky-400/80",      dot: "bg-sky-400" },
};
---


<div class="mt-8">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {skills.map((skill) => {
            const a = accentMap[skill.accent];
            return (
                <div class={`group relative bg-zinc-900/60 backdrop-blur-sm border ${a.border} rounded-2xl p-6 transition-all duration-400 hover:shadow-xl overflow-hidden flex flex-col`}>
                    <div class="absolute inset-0 bg-gradient-to-br from-white/[0.02] to-transparent rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-400 pointer-events-none"></div>

                    <div class="flex items-center gap-3 mb-4">
                        <div class={`w-10 h-10 rounded-xl border flex items-center justify-center text-xl flex-shrink-0 transition-all duration-300 group-hover:scale-110 ${a.icon}`}>
                            {skill.icon}
                        </div>
                        <h3 class={`text-lg font-bold text-white transition-colors duration-300 ${a.hover}`}>
                            {skill.title}
                        </h3>
                    </div>

                    <ul class="space-y-1.5 flex-grow mb-4">
                        {skill.items.map((item) => (
                            <li class="flex items-start gap-2 text-zinc-400 text-sm leading-snug">
                                <span class={`mt-1.5 w-1.5 h-1.5 rounded-full flex-shrink-0 ${a.dot} opacity-70`}></span>
                                {item}
                            </li>
                        ))}
                    </ul>

                    <div class="flex flex-wrap gap-1.5 pt-3 border-t border-zinc-800/60">
                        {skill.tags.map((tag) => (
                            <span class={`px-2 py-0.5 rounded-md bg-zinc-800/70 border text-xs font-medium ${a.tag}`}>
                                {tag}
                            </span>
                        ))}
                    </div>
                </div>
            );
        })}
    </div>

    <div class="mt-8 text-center">
        <div class="inline-flex items-center gap-2 px-6 py-3 bg-gradient-to-r from-purple-500/10 to-violet-500/10 border border-purple-500/30 rounded-full">
            <svg class="w-4 h-4 text-purple-400" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z" clip-rule="evenodd"/>
            </svg>
            <span class="text-purple-300 font-medium text-sm">Siempre aprendiendo y mejorando</span>
        </div>
    </div>
</div>