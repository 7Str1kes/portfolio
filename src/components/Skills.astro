---
const capabilities = [
    {
        icon: "⚙️",
        title: "Plugins Custom para Minecraft",
        description: "Desarrollo plugins Java completamente a medida que transforman tu servidor con sistemas únicos, mecánicas propias e integraciones avanzadas.",
        highlights: [
            "Economías, tiendas, subastas y mercados propios",
            "Minijuegos, eventos y torneos automáticos",
            "Clanes, facciones, rangos y sistema de permisos",
            "Misiones, logros y progresión de jugador",
            "GUIs interactivas y comandos personalizados",
            "Integración con bases de datos MySQL / MongoDB",
        ],
        tags: ["Java", "Spigot", "Paper", "MySQL", "MongoDB"]
    },
    {
        icon: "🧩",
        title: "Configuración de Servidores",
        description: "Setup completo de servidores Minecraft de cualquier modalidad: Survival, PvP, Gens, SkyBlock, o redes multijugador con varios modos de juego.",
        highlights: [
            "Configuración desde cero o migración de servidor existente",
            "Redes con BungeeCord o Velocity",
            "Instalación, ajuste y optimización de plugins",
            "Configuración de mundos, generadores y biomas",
            "Protecciones y sistema de permisos",
            "Optimización de rendimiento y estabilidad de TPS",
        ],
        tags: ["BungeeCord", "Velocity", "Survival", "PvP", "SkyBlock"]
    },
    {
        icon: "👾",
        title: "Bots de Discord Personalizados",
        description: "Bots de Discord hechos a medida que automatizan la gestión de tu comunidad, integran sistemas externos y ofrecen una experiencia completamente propia.",
        highlights: [
            "Moderación avanzada, filtros y sistemas antispam",
            "Tickets de soporte y flujos de atención personalizados",
            "Economía interna, niveles y tablas de clasificación",
            "Integración con servidores de Minecraft y APIs externas",
            "Logs automáticos, estadísticas y dashboards",
            "Comandos slash, menús y formularios interactivos",
        ],
        tags: ["Node.js", "Discord.js", "MongoDB", "MySQL"]
    },
    {
        icon: "🌐",
        title: "Páginas Web",
        description: "Diseño y desarrollo de webs modernas, rápidas y funcionales: desde una landing page profesional hasta sistemas completos con panel propio y lógica de negocio.",
        highlights: [
            "Landing pages, portfolios y webs de presentación",
            "Paneles de administración y dashboards a medida",
            "Tiendas y sistemas de donación integrados",
            "Conexión con APIs externas y servicios propios",
            "Diseño responsive, accesible y optimizado para SEO",
            "Sistemas complementarios para comunidades o servidores",
        ],
        tags: ["Astro", "Next.js", "Vue", "Tailwind", "TypeScript"]
    },
    {
        icon: "🖥️",
        title: "Máquinas, Paneles y Servicios Linux",
        description: "Instalación y configuración completa de infraestructura: desde la máquina hasta el panel de control, proxies inversos y todo lo necesario para mantener tus servicios en marcha.",
        highlights: [
            "Instalación y configuración completa de Pterodactyl",
            "Configuración de VPS, servidores dedicados y entornos Linux",
            "Proxies inversos con Nginx",
            "Servicios systemd, backups automáticos y cronjobs",
            "Redes de Minecraft, gestión de puertos y firewalls",
            "Soporte y mantenimiento de infraestructura continuo",
        ],
        tags: ["Linux", "Pterodactyl", "Nginx"]
    },
]
---

<div class="mt-8">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {capabilities.map((cap, i) => (
            <div class={`group relative bg-gradient-to-br from-zinc-800/40 to-zinc-900/40 backdrop-blur-sm border border-purple-500/20 rounded-2xl p-7 hover:border-purple-500/40 transition-all duration-500 shadow-xl hover:shadow-purple-500/10 overflow-hidden flex flex-col${i === capabilities.length - 1 && capabilities.length % 2 !== 0 ? ' md:col-span-2 md:max-w-xl md:mx-auto md:w-full' : ''}`}>
                <div class="absolute inset-0 bg-gradient-to-br from-purple-500/5 to-transparent rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>

                <div class="relative flex items-center gap-4 mb-5">
                    <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-purple-500/15 to-purple-600/10 border border-purple-500/25 flex items-center justify-center text-2xl flex-shrink-0 group-hover:scale-110 group-hover:border-purple-500/50 transition-all duration-300">
                        {cap.icon}
                    </div>
                    <div>
                        <h3 class="text-lg font-bold text-white group-hover:text-purple-300 transition-colors duration-300 leading-tight">
                            {cap.title}
                        </h3>
                        <p class="text-zinc-400 text-sm mt-0.5 leading-snug">{cap.description}</p>
                    </div>
                </div>

                <ul class="relative space-y-2 flex-grow">
                    {cap.highlights.map((item) => (
                        <li class="flex items-start gap-2.5 text-zinc-300 text-sm">
                            <svg class="w-4 h-4 text-purple-400 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                            </svg>
                            {item}
                        </li>
                    ))}
                </ul>

                <div class="relative flex flex-wrap gap-1.5 mt-5 pt-4 border-t border-zinc-700/40">
                    {cap.tags.map((tag) => (
                        <span class="px-2.5 py-0.5 rounded-md bg-zinc-800/80 border border-zinc-700/50 text-zinc-400 text-xs font-medium">
                            {tag}
                        </span>
                    ))}
                </div>
            </div>
        ))}
    </div>

    <div class="mt-8 text-center">
        <div class="inline-flex items-center gap-2 px-6 py-3 bg-gradient-to-r from-purple-500/10 to-violet-500/10 border border-purple-500/30 rounded-full">
            <svg class="w-5 h-5 text-purple-400" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z" clip-rule="evenodd"/>
            </svg>
            <span class="text-purple-300 font-medium text-sm">Siempre aprendiendo y mejorando</span>
        </div>
    </div>
</div>
