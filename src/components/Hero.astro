---
const skills = ['Java', 'Spigot/Paper', 'Node.js', 'Discord.js', 'Astro', 'MySQL']
---

<canvas id="particles-canvas"></canvas>

<section class="relative min-h-[calc(100vh-72px)] flex items-center overflow-hidden">

    <div class="absolute top-1/3 left-1/4 w-[600px] h-[600px] bg-purple-700/8 rounded-full blur-[140px] pointer-events-none"></div>
    <div class="absolute bottom-1/4 right-1/4 w-[400px] h-[400px] bg-violet-600/6 rounded-full blur-[120px] pointer-events-none"></div>

    <div class="relative w-full max-w-6xl mx-auto px-6 lg:px-8 py-24 flex flex-col lg:flex-row items-center justify-between gap-14 lg:gap-20">

        <div class="flex-1 flex flex-col items-center lg:items-start text-center lg:text-left">

            <div class="flex items-center gap-2.5 mb-8 hero-fade" style="animation-delay: 0ms">
                <div class="relative flex items-center">
                    <div class="w-2 h-2 bg-violet-400 rounded-full"></div>
                    <div class="absolute w-2 h-2 bg-violet-400 rounded-full animate-ping opacity-75"></div>
                </div>
                <span class="text-zinc-400 text-sm tracking-wide">Disponible para proyectos</span>
                <span class="text-zinc-700 mx-1">·</span>
                <span class="text-zinc-500 text-sm">+3 años de experiencia</span>
            </div>

            <h1 class="text-6xl md:text-7xl lg:text-8xl font-black tracking-tighter leading-none mb-5 hero-fade" style="animation-delay: 80ms">
                <span class="bg-gradient-to-r from-violet-400 via-purple-300 to-fuchsia-400 bg-clip-text text-transparent">
                    7Str1kes
                </span>
            </h1>

            <p class="text-sm md:text-base tracking-[0.22em] uppercase mb-8 hero-fade" style="animation-delay: 150ms">
                <span class="text-zinc-500">Desarrollador de</span>
                <span class="text-purple-400 font-semibold"> Software</span>
            </p>

            <p class="text-zinc-300/80 text-base md:text-lg max-w-md leading-relaxed mb-10 hero-fade" style="animation-delay: 220ms">
                Transformo ideas en sistemas reales: desde plugins para Minecraft hasta bots de Discord y webs a medida.
            </p>

            <div class="flex flex-wrap items-center justify-center lg:justify-start gap-4 mb-10 hero-fade" style="animation-delay: 300ms">
                <a
                    href="https://github.com/7Str1kes"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="bg-gradient-to-r from-violet-500 to-purple-600 hover:from-violet-400 hover:to-purple-500 text-white font-semibold px-7 py-3 rounded-full transition-all duration-300 shadow-lg shadow-purple-500/25 hover:shadow-purple-500/40 hover:scale-[1.03] flex items-center gap-2"
                >
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                    </svg>
                    GitHub
                </a>
                <a
                    href="/services"
                    class="border border-zinc-700/80 hover:border-purple-500/40 bg-white/5 hover:bg-purple-500/8 text-zinc-300 hover:text-white font-semibold px-7 py-3 rounded-full transition-all duration-300 flex items-center gap-2"
                >
                    Ver Servicios
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                    </svg>
                </a>
            </div>

            <div class="flex flex-wrap items-center justify-center lg:justify-start gap-2 hero-fade" style="animation-delay: 400ms">
                {skills.map(skill => (
                    <span class="px-3 py-1 text-xs text-zinc-500 border border-zinc-800 rounded-full hover:text-zinc-300 hover:border-purple-500/30 hover:bg-purple-500/5 transition-all duration-200 cursor-default">
                        {skill}
                    </span>
                ))}
            </div>
        </div>

        <div class="relative flex-shrink-0 order-first lg:order-last hero-fade" style="animation-delay: 160ms">

            <div class="absolute inset-0 bg-gradient-to-br from-violet-500/20 to-purple-700/15 rounded-3xl blur-3xl scale-125 pointer-events-none"></div>

            <div class="relative w-56 h-64 md:w-64 md:h-72 lg:w-72 lg:h-80 p-[2px] rounded-3xl bg-gradient-to-br from-violet-500/70 via-purple-500/40 to-fuchsia-500/20 shadow-2xl shadow-purple-500/20">
                <div class="w-full h-full rounded-[22px] overflow-hidden bg-zinc-900">
                    <img
                        src="/head-1.webp"
                        alt="7Str1kes"
                        width="288"
                        height="320"
                        loading="eager"
                        decoding="async"
                        class="w-full h-full object-cover object-top"
                    />
                </div>
            </div>

            <div class="absolute -bottom-5 -left-8 bg-zinc-900/95 border border-zinc-700/60 backdrop-blur-sm rounded-2xl px-4 py-2.5 flex items-center gap-2 shadow-xl">
                <div class="w-2 h-2 bg-emerald-400 rounded-full animate-pulse"></div>
                <span class="text-xs text-zinc-200 font-medium whitespace-nowrap">Open to work</span>
            </div>

            <div class="absolute -top-4 -right-6 bg-zinc-900/95 border border-purple-500/30 backdrop-blur-sm rounded-2xl px-4 py-2.5 shadow-xl">
                <span class="text-xs text-purple-300 font-semibold">+3 años exp.</span>
            </div>
        </div>
    </div>

    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-1.5 opacity-30 hero-fade" style="animation-delay: 600ms">
        <span class="text-zinc-600 text-xs tracking-widest uppercase">Scroll</span>
        <div class="w-px h-8 bg-gradient-to-b from-zinc-600 to-transparent"></div>
    </div>
</section>

<style>
    .hero-fade {
        opacity: 0;
        transform: translateY(16px);
        animation: hero-in 0.6s ease-out forwards;
    }

    @keyframes hero-in {
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    #particles-canvas {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        z-index: 1;
    }
</style>

<script>
    import { initParticles } from '../scripts/particles';
    initParticles('particles-canvas', 50);
</script>
