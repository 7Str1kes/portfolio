---
const currentYear = new Date().getFullYear();
---

<canvas id="footer-particles-canvas"></canvas>

<footer class="mt-auto relative bg-gradient-to-b from-zinc-950 to-black border-t border-zinc-800/50">
    <div class="absolute inset-0 bg-gradient-to-t from-purple-500/5 via-transparent to-transparent pointer-events-none"></div>

    <div class="container mx-auto px-6 py-12 relative z-10">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-10 mb-10">

            <div class="space-y-3">
                <h3 class="text-2xl font-bold bg-gradient-to-r from-purple-400 via-violet-300 to-purple-600 bg-clip-text text-transparent">
                    7Str1kes
                </h3>
                <p class="text-zinc-400 text-sm leading-relaxed">
                    Desarrollador de software especializado en plugins de Minecraft, bots de Discord y desarrollo web.
                </p>
                <p class="text-zinc-600 text-xs">Creando soluciones desde 2023.</p>
            </div>

            <div class="space-y-4">
                <h4 class="text-white text-xs font-semibold uppercase tracking-widest">Navegación</h4>
                <ul class="space-y-2">
                    <li>
                        <a href="/" class="text-zinc-400 hover:text-purple-400 transition-colors duration-200 text-sm">
                            Portfolio
                        </a>
                    </li>
                    <li>
                        <a href="/services" class="text-zinc-400 hover:text-purple-400 transition-colors duration-200 text-sm">
                            Servicios
                        </a>
                    </li>
                    <li>
                        <a href="/reviews" class="text-zinc-400 hover:text-purple-400 transition-colors duration-200 text-sm">
                            Reseñas
                        </a>
                    </li>
                    <li>
                        <a href="/projects" class="text-zinc-400 hover:text-purple-400 transition-colors duration-200 text-sm">
                            Proyectos
                        </a>
                    </li>
                </ul>
            </div>

            <div class="space-y-4">
                <h4 class="text-white text-xs font-semibold uppercase tracking-widest">Contacto</h4>
                <div class="space-y-3">
                    <div class="flex items-center gap-2.5">
                        <svg class="w-4 h-4 text-purple-400 shrink-0" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03z"/>
                        </svg>
                        <span class="text-zinc-400 text-sm">7str1kes</span>
                    </div>
                    <div class="flex items-center gap-2.5" id="footer-email-row">
                        <svg class="w-4 h-4 text-purple-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                        </svg>
                        <span id="footer-email" class="text-zinc-400 text-sm">···</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="border-t border-zinc-800/60 pt-6 flex flex-col sm:flex-row items-center justify-between gap-2">
            <p class="text-zinc-600 text-xs">© {currentYear} 7Str1kes. Todos los derechos reservados.</p>
            <p class="text-zinc-600 text-xs">
                Desarrollado por <span class="text-purple-400/80 font-medium">GL Studios</span>
            </p>
        </div>
    </div>
</footer>

<style>
    #footer-particles-canvas {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        z-index: 1;
    }
</style>

<script>
    const footerEmail = document.getElementById('footer-email');
    if (footerEmail) {
        footerEmail.textContent = ['myfuncdev', 'gmail.com'].join('@');
    }

    import { initFooterParticles } from '../scripts/particles';
    initFooterParticles('footer-particles-canvas', 30);
</script>
