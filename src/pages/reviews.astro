---
import "../styles/global.css";
import Layout from '../layouts/Layout.astro';
import SectionContainer from "../components/SectionContainer.astro";

const reviews = [
    {
        server: "Página Web",
        reviewerNick: "https.klev",
        reviewerRole: "Cliente",
        myRole: null,
        logo: null,
        logoIcon: "🌐",
        rating: 5,
        comment: "El desarrollador aparte de muy amable y comunicativo, me solicitó todo lo que yo quería para la realización de la página web y lo realizó al pie de la letra. Cumpliendo con mis expectativas en su totalidad. Además ofreció siempre la posibilidad de mejorar la página en caso de no cumplir o satisfacer mis expectativas, lo cual fue de mi agrado.",
        date: "2026",
        publicLink: "https://www.j2bklev.com/",
        publicLinkLabel: null,
        githubRepo: null,
    }
];
---

<Layout
    title="Mis Clientes - 7Str1kes"
    description="Opiniones y reviews de clientes que han trabajado con mis servicios"
>
    <canvas id="particles-canvas"></canvas>
    <main class="px-4">
        <SectionContainer class="py-24">

            <div class="text-center mb-16">
                <div class="inline-block px-4 py-2 bg-purple-500/10 border border-purple-500/20 rounded-full text-purple-400 text-sm font-medium mb-6">
                    ⭐ Opiniones reales
                </div>
                <h1 class="text-5xl md:text-7xl font-bold text-white mb-6 leading-tight">
                    Mis <span class="text-transparent bg-clip-text bg-gradient-to-r from-violet-400 to-purple-500">Clientes</span>
                </h1>
                <p class="text-xl text-zinc-400">Lo que dicen quienes han trabajado conmigo</p>
            </div>

            {reviews.some(r => r.logo) && (
                <div class="mb-16 max-w-4xl mx-auto overflow-hidden relative py-4 [mask-image:linear-gradient(to_right,transparent,black_10%,black_90%,transparent)]">
                    <div class="flex gap-12 w-max [animation:scroll-logos_25s_linear_infinite] hover:[animation-play-state:paused]">
                        {(() => {
                            const logoReviews = reviews.filter(r => r.logo);
                            return [...logoReviews, ...logoReviews, ...logoReviews];
                        })().map((r) => (
                            <div class="shrink-0 flex items-center gap-3 opacity-60 hover:opacity-100 transition-opacity duration-300">
                                <img src={r.logo!} alt={r.server} class="w-10 h-10 rounded-full object-cover" />
                                <span class="text-zinc-300 font-semibold text-sm whitespace-nowrap">{r.server}</span>
                            </div>
                        ))}
                    </div>
                </div>
            )}

            <div class="max-w-3xl mx-auto relative" id="carousel">
                {reviews.length > 1 && (
                    <>
                        <button
                            id="prev-btn"
                            class="absolute left-0 top-1/2 -translate-y-1/2 -translate-x-4 md:-translate-x-14 z-10 w-11 h-11 rounded-full bg-zinc-800/80 border border-zinc-700/50 hover:border-purple-500/50 hover:bg-zinc-700/80 flex items-center justify-center transition-all duration-300 hover:shadow-lg hover:shadow-purple-500/10 cursor-pointer"
                        >
                            <svg class="w-5 h-5 text-zinc-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                            </svg>
                        </button>
                        <button
                            id="next-btn"
                            class="absolute right-0 top-1/2 -translate-y-1/2 translate-x-4 md:translate-x-14 z-10 w-11 h-11 rounded-full bg-zinc-800/80 border border-zinc-700/50 hover:border-purple-500/50 hover:bg-zinc-700/80 flex items-center justify-center transition-all duration-300 hover:shadow-lg hover:shadow-purple-500/10 cursor-pointer"
                        >
                            <svg class="w-5 h-5 text-zinc-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                            </svg>
                        </button>
                    </>
                )}

                <div class="overflow-hidden">
                    <div id="slides-track" class="flex transition-transform duration-500 ease-in-out">
                        {reviews.map((review) => (
                            <div class="w-full shrink-0 px-2">
                                <div class="group bg-gradient-to-br from-zinc-800/50 to-zinc-900/50 backdrop-blur-sm border border-zinc-700/50 rounded-2xl p-8 md:p-10 hover:border-purple-500/30 transition-all duration-500 relative overflow-hidden">
                                    <div class="absolute inset-0 bg-gradient-to-r from-purple-500/5 to-transparent rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

                                    <div class="relative flex items-center gap-4 mb-5">
                                        {review.logo ? (
                                            <img
                                                src={review.logo}
                                                alt={review.server}
                                                class="w-14 h-14 rounded-full object-cover border-2 border-zinc-700/50 group-hover:border-purple-500/40 transition-colors duration-300 flex-shrink-0"
                                            />
                                        ) : (
                                            <div class="w-14 h-14 rounded-full border-2 border-zinc-700/50 group-hover:border-purple-500/40 transition-colors duration-300 bg-zinc-800/80 flex items-center justify-center text-2xl flex-shrink-0">
                                                {review.logoIcon}
                                            </div>
                                        )}
                                        <div class="flex-1 min-w-0">
                                            <h3 class="text-xl font-bold text-white group-hover:text-purple-400 transition-colors duration-300">{review.server}</h3>
                                            <p class="text-zinc-500 text-xs mt-0.5">{review.date}</p>
                                        </div>
                                        <div class="flex gap-0.5 flex-shrink-0">
                                            {Array.from({ length: review.rating }).map(() => (
                                                <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                                                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                                                </svg>
                                            ))}
                                        </div>
                                    </div>

                                    <div class="relative flex items-center gap-2 mb-5 p-3 rounded-xl bg-zinc-900/40 border border-zinc-700/30">
                                        <svg class="w-3.5 h-3.5 text-zinc-500 shrink-0" fill="currentColor" viewBox="0 0 20 20">
                                            <path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd"/>
                                        </svg>
                                        <span class="text-zinc-300 text-sm font-medium">{review.reviewerNick}</span>
                                        <span class="px-1.5 py-0.5 rounded text-[11px] font-semibold bg-zinc-700/60 text-zinc-400 border border-zinc-600/50">{review.reviewerRole}</span>
                                    </div>

                                    <blockquote class="relative text-zinc-300 leading-relaxed text-base italic mb-6">
                                        "{review.comment}"
                                    </blockquote>

                                    <div class="relative flex flex-wrap items-center justify-between gap-3 pt-4 border-t border-zinc-700/30">
                                        <div class="flex flex-wrap gap-2">
                                            {review.myRole && (
                                                <span class="px-2 py-0.5 rounded text-[11px] font-semibold bg-purple-500/15 text-purple-300 border border-purple-500/30">{review.myRole}</span>
                                            )}
                                        </div>
                                        <div class="flex items-center gap-2">
                                            {review.publicLink && (
                                                <a
                                                    href={review.publicLink}
                                                    target="_blank"
                                                    rel="noopener noreferrer"
                                                    class="inline-flex items-center gap-1.5 px-3 py-1 rounded-lg bg-zinc-800/80 border border-zinc-700/50 hover:border-purple-500/40 hover:text-purple-300 text-zinc-400 text-xs font-medium transition-all duration-200"
                                                    title={review.publicLinkLabel ?? "Ver proyecto"}
                                                >
                                                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                                                    </svg>
                                                    {review.publicLinkLabel ?? "Ver proyecto"}
                                                </a>
                                            )}
                                            {review.githubRepo && (
                                                <a
                                                    href={review.githubRepo}
                                                    target="_blank"
                                                    rel="noopener noreferrer"
                                                    class="inline-flex items-center gap-1.5 px-3 py-1 rounded-lg bg-zinc-800/80 border border-zinc-700/50 hover:border-purple-500/40 hover:text-purple-300 text-zinc-400 text-xs font-medium transition-all duration-200"
                                                    title="Ver repositorio"
                                                >
                                                    <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
                                                        <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                                                    </svg>
                                                    GitHub
                                                </a>
                                            )}
                                        </div>
                                    </div>
                                </div>
                            </div>
                        ))}
                    </div>
                </div>

                {reviews.length > 1 && (
                    <div class="flex justify-center gap-2 mt-6">
                        {reviews.map((_, i) => (
                            <button
                                data-dot={i}
                                class={`carousel-dot w-2.5 h-2.5 rounded-full transition-all duration-300 cursor-pointer ${i === 0 ? 'bg-purple-500 w-6' : 'bg-zinc-600 hover:bg-zinc-500'}`}
                            />
                        ))}
                    </div>
                )}
            </div>

        </SectionContainer>
    </main>
</Layout>

<style>
    #particles-canvas {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        z-index: 1;
    }
</style>

<script>
    const track = document.getElementById('slides-track') as HTMLElement;
    const prevBtn = document.getElementById('prev-btn') as HTMLButtonElement | null;
    const nextBtn = document.getElementById('next-btn') as HTMLButtonElement | null;
    const dots = document.querySelectorAll('.carousel-dot');
    const totalSlides = dots.length;
    let current = 0;

    function goTo(index: number) {
        current = ((index % totalSlides) + totalSlides) % totalSlides;
        track.style.transform = `translateX(-${current * 100}%)`;
        dots.forEach((dot, i) => {
            if (i === current) {
                dot.classList.remove('bg-zinc-600', 'hover:bg-zinc-500');
                dot.classList.add('bg-purple-500', 'w-6');
            } else {
                dot.classList.remove('bg-purple-500', 'w-6');
                dot.classList.add('bg-zinc-600', 'hover:bg-zinc-500');
            }
        });
    }

    prevBtn?.addEventListener('click', () => goTo(current - 1));
    nextBtn?.addEventListener('click', () => goTo(current + 1));
    dots.forEach((dot) => {
        dot.addEventListener('click', () => {
            const index = Number((dot as HTMLElement).dataset.dot);
            goTo(index);
        });
    });

    document.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowLeft') goTo(current - 1);
        if (e.key === 'ArrowRight') goTo(current + 1);
    });

    if (track) {
        let touchStartX = 0;
        track.addEventListener('touchstart', (e) => {
            touchStartX = e.touches[0].clientX;
        }, { passive: true });
        track.addEventListener('touchend', (e) => {
            const delta = touchStartX - e.changedTouches[0].clientX;
            if (Math.abs(delta) > 50) goTo(delta > 0 ? current + 1 : current - 1);
        }, { passive: true });
    }

    import { initParticles } from '../scripts/particles';
    initParticles('particles-canvas', 50);
</script>