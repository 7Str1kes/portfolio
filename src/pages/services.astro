---
import "../styles/global.css";
import Layout from '../layouts/Layout.astro';
import SectionContainer from "../components/SectionContainer.astro";

const services = [
    {
        title: "Plugins Custom para Minecraft",
        icon: "⚙️",
        accent: "purple",
        description: "Desarrollo plugins Java completamente a medida que transforman tu servidor con sistemas únicos, mecánicas propias e integraciones avanzadas.",
        features: [
            "Economías, tiendas, subastas y mercados propios",
            "Minijuegos, eventos y torneos automáticos",
            "Clanes, facciones, rangos y sistema de permisos",
            "Misiones, logros y progresión de jugador",
            "GUIs interactivas y comandos personalizados",
            "Integración con bases de datos MySQL / MongoDB",
            "Optimización de rendimiento y compatibilidad",
            "APIs propias e integración con otros plugins",
        ],
        tags: ["Java", "Spigot", "Paper", "MySQL", "MongoDB"],
    },
    {
        title: "Configuración de Servidores",
        icon: "🧩",
        accent: "violet",
        description: "Setup completo de servidores Minecraft de cualquier modalidad: Survival, PvP, Gens, SkyBlock, o redes multijugador con varios modos de juego.",
        features: [
            "Configuración desde cero o migración de servidor existente",
            "Redes multijugador con BungeeCord o Velocity",
            "Instalación, ajuste y optimización de plugins",
            "Configuración de mundos, generadores y biomas",
            "Protecciones y permisos",
            "Optimización de rendimiento y estabilidad de TPS",
            "Sistemas de backup y recuperación ante fallos",
            "Soporte técnico durante y tras la configuración",
        ],
        tags: ["BungeeCord", "Velocity", "Survival", "PvP", "SkyBlock"],
    },
    {
        title: "Bots de Discord Personalizados",
        icon: "👾",
        accent: "purple",
        description: "Bots de Discord hechos a medida que automatizan la gestión de tu comunidad, integran sistemas externos y ofrecen una experiencia completamente propia.",
        features: [
            "Moderación avanzada, filtros y sistemas antispam",
            "Tickets de soporte y flujos de atención personalizados",
            "Economía interna, niveles y tablas de clasificación",
            "Integración con servidores de Minecraft y APIs externas",
            "Logs automáticos, estadísticas y dashboards",
            "Comandos slash, menús y formularios interactivos",
            "Sistemas de verificación y roles automáticos",
            "Notificaciones, alertas y automatizaciones programadas",
        ],
        tags: ["Node.js", "Discord.js", "MongoDB", "MySQL"],
    },
    {
        title: "Páginas Web",
        icon: "🌐",
        accent: "violet",
        description: "Diseño y desarrollo de webs modernas, rápidas y funcionales: desde una landing page profesional hasta sistemas completos con panel propio y lógica de negocio.",
        features: [
            "Landing pages, portfolios y webs de presentación",
            "Paneles de administración y dashboards a medida",
            "Tiendas y sistemas de donación integrados",
            "Conexión con APIs externas y servicios propios",
            "Diseño responsive, accesible y optimizado para SEO",
            "Sistemas complementarios para comunidades o servidores",
            "Autenticación, sesiones y gestión de usuarios",
            "Despliegue y configuración en producción",
        ],
        tags: ["Astro", "Next.js", "Vue", "Tailwind", "TypeScript"],
    },
    {
        title: "Máquinas Linux y Paneles Pterodactyl",
        icon: "🖥️",
        accent: "emerald",
        description: "Instalación y configuración completa de infraestructura: desde la máquina hasta el panel de control, proxies inversos y todo lo necesario para mantener tus servicios en marcha.",
        features: [
            "Instalación y configuración completa de Pterodactyl (panel + Wings)",
            "Configuración de VPS, servidores dedicados y entornos Linux",
            "Proxies inversos con Nginx y certificados SSL",
            "Backups automáticos",
            "Gestión de puertos, firewalls y redes de Minecraft",
            "Monitorización, alertas y logs del sistema",
            "Migración de servidores y recuperación de datos",
            "Soporte y mantenimiento de infraestructura continuo",
        ],
        tags: ["Linux", "Pterodactyl", "Nginx", "Apache"],
    },
];

const rows: (typeof services)[] = [];
for (let i = 0; i < services.length; i += 2) {
    rows.push(services.slice(i, i + 2));
}
---

<Layout
    title="Servicios - 7Str1kes"
    description="Servicios profesionales de desarrollo: plugins de Minecraft, bots de Discord, webs, configuración de servidores e infraestructura Linux"
>
    <canvas id="particles-canvas"></canvas>
    <main class="px-4">
        <SectionContainer class="py-24">

            <div class="text-center mb-20">
                <div class="inline-block px-4 py-2 bg-purple-500/10 border border-purple-500/20 rounded-full text-purple-400 text-sm font-medium mb-6">
                    ✨ Soluciones Personalizadas
                </div>
                <h1 class="text-5xl md:text-7xl font-bold text-white mb-6 leading-tight">
                    Servicios <span class="text-transparent bg-clip-text bg-gradient-to-r from-violet-400 to-purple-500">Profesionales</span>
                </h1>
                <p class="text-xl text-zinc-400 max-w-2xl mx-auto leading-relaxed">
                    Desarrollo de software a medida para tu servidor, comunidad o negocio. Calidad, eficiencia y soporte garantizado.
                </p>
            </div>

            <div class="max-w-6xl mx-auto space-y-6">
                {rows.map((row) => (
                    <div class={`grid gap-6 ${row.length === 2 ? 'md:grid-cols-2' : 'grid-cols-1 max-w-3xl mx-auto'}`}>
                        {row.map((service) => {
                            const isEmerald = service.accent === 'emerald';
                            const isViolet = service.accent === 'violet';
                            const borderClass = isEmerald
                                ? 'border-emerald-500/25 hover:border-emerald-500/45 hover:shadow-emerald-500/10'
                                : isViolet
                                    ? 'border-violet-500/25 hover:border-violet-500/45 hover:shadow-violet-500/15'
                                    : 'border-purple-500/25 hover:border-purple-500/45 hover:shadow-purple-500/15';
                            const glowClass = isEmerald
                                ? 'bg-gradient-to-br from-emerald-500/5 to-transparent'
                                : isViolet
                                    ? 'bg-gradient-to-br from-violet-500/5 to-transparent'
                                    : 'bg-gradient-to-br from-purple-500/5 to-transparent';
                            const blobClass = isEmerald ? 'bg-emerald-600/10' : isViolet ? 'bg-violet-600/10' : 'bg-purple-600/10';
                            const iconClass = isEmerald
                                ? 'bg-gradient-to-br from-emerald-500/15 to-emerald-700/10 border-emerald-500/30 group-hover:border-emerald-500/60'
                                : isViolet
                                    ? 'bg-gradient-to-br from-violet-500/15 to-violet-700/10 border-violet-500/30 group-hover:border-violet-500/60'
                                    : 'bg-gradient-to-br from-purple-500/15 to-purple-700/10 border-purple-500/30 group-hover:border-purple-500/60';
                            const titleHover = isEmerald ? 'group-hover:text-emerald-300' : isViolet ? 'group-hover:text-violet-300' : 'group-hover:text-purple-300';
                            const checkColor = isEmerald ? 'text-emerald-400' : isViolet ? 'text-violet-400' : 'text-purple-400';
                            const dotColor = isEmerald ? 'bg-emerald-400' : isViolet ? 'bg-violet-400' : 'bg-purple-400';
                            const featureHover = isEmerald ? 'hover:border-emerald-500/30' : isViolet ? 'hover:border-violet-500/30' : 'hover:border-purple-500/30';

                            return (
                                <div class={`group relative backdrop-blur-sm rounded-3xl p-8 transition-all duration-500 shadow-2xl overflow-hidden border bg-gradient-to-br from-zinc-800/30 to-zinc-900/60 ${borderClass}`}>
                                    <div class={`absolute inset-0 rounded-3xl opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none ${glowClass}`}></div>
                                    <div class={`absolute -top-20 -right-20 w-56 h-56 rounded-full blur-3xl opacity-30 group-hover:opacity-60 transition-opacity duration-500 pointer-events-none ${blobClass}`}></div>

                                    <div class="relative flex items-center gap-4 mb-5">
                                        <div class={`w-13 h-13 w-12 h-12 rounded-2xl flex items-center justify-center text-2xl flex-shrink-0 border transition-all duration-300 group-hover:scale-110 ${iconClass}`}>
                                            {service.icon}
                                        </div>
                                        <div>
                                            <h2 class={`text-xl font-bold text-white transition-colors duration-300 ${titleHover}`}>
                                                {service.title}
                                            </h2>
                                            <p class="text-zinc-400 text-sm leading-snug mt-0.5">{service.description}</p>
                                        </div>
                                    </div>

                                    <ul class="relative space-y-1.5 mb-5">
                                        {service.features.map(feature => (
                                            <li class={`flex items-start gap-2.5 p-2.5 rounded-xl bg-zinc-900/40 border border-zinc-800/50 transition-all duration-300 hover:bg-zinc-800/50 ${featureHover}`}>
                                                <svg class={`w-4 h-4 flex-shrink-0 mt-0.5 ${checkColor}`} fill="currentColor" viewBox="0 0 20 20">
                                                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                                                </svg>
                                                <span class="text-zinc-300 hover:text-white transition-colors text-sm leading-relaxed">{feature}</span>
                                            </li>
                                        ))}
                                    </ul>

                                    <div class="relative flex flex-wrap items-center justify-between gap-3 pt-4 border-t border-zinc-800/50">
                                        <div class="flex flex-wrap gap-1.5">
                                            {service.tags.map(tag => (
                                                <span class="px-2.5 py-0.5 rounded-md bg-zinc-800/80 border border-zinc-700/50 text-zinc-400 text-xs font-medium">
                                                    {tag}
                                                </span>
                                            ))}
                                        </div>
                                        <div class="flex items-center gap-2">
                                            <div class={`w-2 h-2 rounded-full animate-pulse ${dotColor}`}></div>
                                            <span class="text-xs text-zinc-500">Disponible</span>
                                        </div>
                                    </div>
                                </div>
                            );
                        })}
                    </div>
                ))}
            </div>

            <div class="mt-20 text-center">
                <div class="group relative bg-gradient-to-br from-zinc-800/40 to-zinc-900/40 backdrop-blur-sm border border-purple-500/30 hover:border-purple-500/50 rounded-2xl p-10 max-w-3xl mx-auto transition-all duration-500 hover:shadow-2xl hover:shadow-purple-500/20 overflow-hidden">
                    <div class="absolute inset-0 bg-gradient-to-r from-purple-500/5 to-transparent rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>
                    <div class="relative space-y-5">
                        <h2 class="text-3xl md:text-4xl font-bold text-white group-hover:text-purple-300 transition-colors duration-300">
                            ¿Tienes un proyecto en mente?
                        </h2>
                        <p class="text-lg text-zinc-400 leading-relaxed max-w-xl mx-auto">
                            Cada proyecto es diferente. Contáctame para hablar sobre lo que necesitas y encontrar la mejor solución.
                        </p>
                        <div class="flex flex-wrap gap-4 justify-center pt-2">
                            <a href="/#contact" class="bg-gradient-to-r from-violet-500 to-purple-600 hover:from-violet-400 hover:to-purple-500 text-white font-semibold px-8 py-3.5 rounded-full transition-all duration-300 shadow-lg shadow-purple-500/25 hover:shadow-purple-500/40 hover:scale-[1.03] flex items-center gap-2">
                                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                                    <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"/>
                                    <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"/>
                                </svg>
                                Contactar
                            </a>
                            <a href="/reviews" class="border border-zinc-700/80 hover:border-purple-500/40 bg-white/5 hover:bg-purple-500/8 text-zinc-300 hover:text-white font-semibold px-8 py-3.5 rounded-full transition-all duration-300 flex items-center gap-2">
                                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                                </svg>
                                Ver Reseñas
                            </a>
                        </div>
                    </div>
                </div>
            </div>

        </SectionContainer>
    </main>
</Layout>

<style>
    #particles-canvas {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        z-index: 1;
    }
</style>

<script>
    import { initParticles } from '../scripts/particles';
    initParticles('particles-canvas', 50);
</script>