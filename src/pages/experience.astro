---
import "../styles/global.css";
import Layout from '../layouts/Layout.astro';
import SectionContainer from "../components/SectionContainer.astro";

const reviews = [
    {
        server: "GoldenLyons Network",
        reviewerNick: "Toni1487P",
        reviewerRole: "Owner",
        myRole: "Co-Owner & Developer",
        logo: "/reviews-logos/goldenlyons-network.webp",
        comment: "7Strikes dentro de GoldenLyons, ha demostrado un rendimiento excelente como Co-Owner y Developer, cumpliendo y superando expectativas en cada tarea que asume.\nSu nivel técnico, capacidad para liderar y compromiso constante han sido claves para el crecimiento y la estabilidad del proyecto. Resuelve problemas rápido, toma buenas decisiones y siempre busca mejorar el funcionamiento general del equipo.\nDestaca especialmente por su rapidez, responsabilidad y predisposición para colaborar cuando se lo necesita.\nLo recomiendo sin dudar para cualquier proyecto que busque alguien confiable, eficiente y realmente comprometido.",
        initialDate: "2025",
        endDate: "2025"
    },
    {
        server: "Widow Network",
        role: "Co-Owner",
        logo: "/reviews-logos/widow-network.webp",
        comment: "Durante todo el tiempo que ha trabajado en Widow, ha demostrado un desempeño sobresaliente, desempeñándose con excelencia como manager y developer, así como en otras responsabilidades clave. Su alto nivel técnico, capacidad de liderazgo y compromiso constante han sido fundamentales para el crecimiento y buen funcionamiento del equipo. Además de su profesionalismo, destaca por su calidad humana y su disposición para colaborar. Recomiendo plenamente su trabajo.",
        initialDate: "2023",
        endDate: "2025"
    }
];
---

<Layout
    title="Experiencias de Clientes - 7Strikes"
    description="Opiniones y reviews de servidores que han trabajado con mis servicios"
>
    <canvas id="particles-canvas"></canvas>
    <main class="px-4">
        <SectionContainer class="py-24">
            <div class="text-center mb-16">
                <h1 class="text-5xl md:text-6xl font-bold text-white mb-4">Experiencia</h1>
            </div>

            <div class="mb-16 max-w-4xl mx-auto overflow-hidden relative py-4 [mask-image:linear-gradient(to_right,transparent,black_10%,black_90%,transparent)]">
                <div class="flex gap-12 w-max [animation:scroll-logos_25s_linear_infinite] hover:[animation-play-state:paused]">
                    {(() => { const logoReviews = reviews.filter(r => r.logo); return [...logoReviews, ...logoReviews, ...logoReviews]; })().map((r) => (
                        <div class="shrink-0 flex items-center gap-3 opacity-60 hover:opacity-100 transition-opacity duration-300">
                            <img src={r.logo!} alt={r.server} class="w-10 h-10 rounded-full object-cover" />
                            <span class="text-zinc-300 font-semibold text-sm whitespace-nowrap">{r.server}</span>
                        </div>
                    ))}
                </div>
            </div>

            <div class="max-w-3xl mx-auto relative" id="carousel">
                <button
                    id="prev-btn"
                    class="absolute left-0 top-1/2 -translate-y-1/2 -translate-x-4 md:-translate-x-14 z-10 w-11 h-11 rounded-full bg-zinc-800/80 border border-zinc-700/50 hover:border-purple-500/50 hover:bg-zinc-700/80 flex items-center justify-center transition-all duration-300 hover:shadow-lg hover:shadow-purple-500/10 cursor-pointer"
                >
                    <svg class="w-5 h-5 text-zinc-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                    </svg>
                </button>

                <button
                    id="next-btn"
                    class="absolute right-0 top-1/2 -translate-y-1/2 translate-x-4 md:translate-x-14 z-10 w-11 h-11 rounded-full bg-zinc-800/80 border border-zinc-700/50 hover:border-purple-500/50 hover:bg-zinc-700/80 flex items-center justify-center transition-all duration-300 hover:shadow-lg hover:shadow-purple-500/10 cursor-pointer"
                >
                    <svg class="w-5 h-5 text-zinc-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                </button>

                <div class="overflow-hidden">
                    <div id="slides-track" class="flex transition-transform duration-500 ease-in-out">
                        {reviews.map((review) => (
                            <div class="w-full shrink-0 px-2">
                                <div class="group bg-gradient-to-br from-zinc-800/50 to-zinc-900/50 backdrop-blur-sm border border-zinc-700/50 rounded-2xl p-8 md:p-10 hover:border-purple-500/30 transition-all duration-500 relative overflow-hidden">
                                    <div class="absolute inset-0 bg-gradient-to-r from-purple-500/5 to-transparent rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

                                    <div class="relative flex items-center gap-4 mb-5">
                                        <img
                                                src={review.logo}
                                                alt={review.server}
                                                class="w-14 h-14 rounded-full object-cover border-2 border-zinc-700/50 group-hover:border-purple-500/40 transition-colors duration-300"
                                            />
                                        <div class="flex-1 min-w-0">
                                            <h3 class="text-xl font-bold text-white group-hover:text-purple-400 transition-colors duration-300">{review.server}</h3>
                                        </div>
                                        <div class="flex gap-0.5">
                                            {Array.from({ length: review.rating }).map(() => (
                                                <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                                                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                                                </svg>
                                            ))}
                                        </div>
                                    </div>

                                    <div class="relative flex items-center gap-2 mb-5 p-3 rounded-xl bg-zinc-900/40 border border-zinc-700/30">
                                        <svg class="w-3.5 h-3.5 text-zinc-500 shrink-0" fill="currentColor" viewBox="0 0 20 20">
                                            <path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd"/>
                                        </svg>
                                        <span class="text-zinc-300 text-sm font-medium">{review.reviewerNick}</span>
                                        <span class="px-1.5 py-0.5 rounded text-[11px] font-semibold bg-zinc-700/60 text-zinc-400 border border-zinc-600/50">{review.reviewerRole}</span>
                                    </div>

                                    <blockquote class="relative text-zinc-300 leading-relaxed text-lg italic mb-6">
                                        "{review.comment}"
                                    </blockquote>

                                    <div class="relative flex items-center justify-between pt-4 border-t border-zinc-700/30">
                                        <span class="text-zinc-500 text-sm">{review.date}</span>
                                        {review.myRole && (
                                            <span class="px-2 py-0.5 rounded text-[11px] font-semibold bg-purple-500/15 text-purple-300 border border-purple-500/30">{review.myRole}</span>
                                        )}
                                    </div>
                                </div>
                            </div>
                        ))}
                    </div>
                </div>

                <div class="flex justify-center gap-2 mt-6">
                    {reviews.map((_, i) => (
                        <button
                            data-dot={i}
                            class={`carousel-dot w-2.5 h-2.5 rounded-full transition-all duration-300 cursor-pointer ${i === 0 ? 'bg-purple-500 w-6' : 'bg-zinc-600 hover:bg-zinc-500'}`}
                        />
                    ))}
                </div>
            </div>

            <div class="mt-16 text-center">
                <div class="group relative bg-gradient-to-br from-zinc-800/40 to-zinc-900/40 backdrop-blur-sm border border-zinc-700/50 hover:border-purple-500/50 rounded-xl p-8 max-w-3xl mx-auto transition-all duration-500 hover:shadow-xl hover:shadow-purple-500/10 overflow-hidden">
                    <div class="absolute inset-0 bg-gradient-to-r from-purple-500/5 to-transparent rounded-xl opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

                    <div class="relative">
                        <h2 class="text-2xl md:text-3xl font-bold text-white mb-4 group-hover:text-purple-400 transition-colors duration-300">¿Quieres trabajar conmigo?</h2>
                        <p class="text-zinc-300 mb-6 text-lg leading-relaxed">
                            Si tu servidor necesita adaptación Java/Bedrock o configuración profesional de plugins, contáctame y hablemos sobre tu proyecto.
                        </p>
                        <div class="flex flex-wrap gap-4 justify-center">
                            <a href="/" class="group/btn relative bg-gradient-to-r from-purple-500 to-purple-600 hover:from-purple-600 hover:to-violet-700 text-white font-semibold px-8 py-3 rounded-lg transition-all duration-300 shadow-lg shadow-purple-500/30 hover:shadow-purple-500/50 hover:scale-105 overflow-hidden">
                                <span class="relative z-10">Ver Portafolio</span>
                                <div class="absolute inset-0 bg-gradient-to-r from-purple-400 to-violet-600 opacity-0 group-hover/btn:opacity-100 transition-opacity duration-300"></div>
                            </a>
                            <a href="/services" class="group/btn relative bg-zinc-800/80 backdrop-blur-sm hover:bg-zinc-700/80 text-white font-semibold px-8 py-3 rounded-lg transition-all duration-300 border border-zinc-600/50 hover:border-purple-400/60 hover:scale-105 overflow-hidden">
                                <span class="relative z-10 group-hover/btn:text-purple-400 transition-colors">Ver Servicios</span>
                                <div class="absolute inset-0 bg-purple-500/10 opacity-0 group-hover/btn:opacity-100 transition-opacity duration-300"></div>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </SectionContainer>
    </main>
</Layout>

<style>
    #particles-canvas {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        z-index: 1;
    }
</style>

<script>
    const track = document.getElementById('slides-track') as HTMLElement;
    const prevBtn = document.getElementById('prev-btn') as HTMLButtonElement;
    const nextBtn = document.getElementById('next-btn') as HTMLButtonElement;
    const dots = document.querySelectorAll('.carousel-dot');
    const totalSlides = dots.length;
    let current = 0;

    function goTo(index: number) {
        current = ((index % totalSlides) + totalSlides) % totalSlides;
        track.style.transform = `translateX(-${current * 100}%)`;
        dots.forEach((dot, i) => {
            if (i === current) {
                dot.classList.remove('bg-zinc-600', 'hover:bg-zinc-500');
                dot.classList.add('bg-purple-500', 'w-6');
            } else {
                dot.classList.remove('bg-purple-500', 'w-6');
                dot.classList.add('bg-zinc-600', 'hover:bg-zinc-500');
            }
        });
    }

    prevBtn.addEventListener('click', () => goTo(current - 1));
    nextBtn.addEventListener('click', () => goTo(current + 1));
    dots.forEach((dot) => {
        dot.addEventListener('click', () => {
            const index = Number((dot as HTMLElement).dataset.dot);
            goTo(index);
        });
    });

    document.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowLeft') goTo(current - 1);
        if (e.key === 'ArrowRight') goTo(current + 1);
    });

    let touchStartX = 0;
    track.addEventListener('touchstart', (e) => {
        touchStartX = e.touches[0].clientX;
    }, { passive: true });
    track.addEventListener('touchend', (e) => {
        const delta = touchStartX - e.changedTouches[0].clientX;
        if (Math.abs(delta) > 50) goTo(delta > 0 ? current + 1 : current - 1);
    }, { passive: true });

    import { initParticles } from '../scripts/particles';
    initParticles('particles-canvas', 50);
</script>
