---
import "../styles/global.css";
import Layout from '../layouts/Layout.astro';
---

<Layout
    title="404 - Página no encontrada"
    description="Esta página no existe"
>
    <canvas id="particles-canvas"></canvas>
    <main class="min-h-screen flex items-center justify-center px-4">
        <div class="text-center space-y-8 max-w-lg mx-auto">

            <div class="relative inline-block">
                <span class="text-[10rem] font-black text-transparent bg-clip-text bg-gradient-to-b from-purple-400 via-violet-300 to-purple-600/30 leading-none select-none">
                    404
                </span>
                <div class="absolute inset-0 bg-gradient-to-b from-purple-500/10 to-transparent blur-3xl -z-10"></div>
            </div>

            <div class="space-y-3">
                <h1 class="text-2xl md:text-3xl font-bold text-white">
                    Página no encontrada
                </h1>
                <p class="text-zinc-400 text-lg leading-relaxed">
                    La ruta que buscas no existe o fue movida.<br/>Vuelve al inicio para continuar.
                </p>
            </div>

            <div class="flex flex-wrap gap-4 justify-center pt-2">
                <a
                    href="/"
                    class="group relative bg-gradient-to-r from-purple-500 to-purple-600 hover:from-purple-600 hover:to-violet-700 text-white font-semibold px-8 py-3.5 rounded-xl transition-all duration-300 shadow-lg shadow-purple-500/30 hover:shadow-purple-500/50 hover:scale-105 overflow-hidden flex items-center gap-2"
                >
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
                    </svg>
                    <span class="relative z-10">Volver al inicio</span>
                    <div class="absolute inset-0 bg-gradient-to-r from-purple-400 to-violet-600 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
                </a>
                <a
                    href="/services"
                    class="group relative bg-zinc-800/80 backdrop-blur-sm hover:bg-zinc-700/80 text-white font-semibold px-8 py-3.5 rounded-xl transition-all duration-300 border border-zinc-600/50 hover:border-purple-400/60 hover:scale-105 overflow-hidden flex items-center gap-2"
                >
                    <span class="relative z-10 group-hover:text-purple-400 transition-colors">Ver Servicios</span>
                    <div class="absolute inset-0 bg-purple-500/10 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
                </a>
            </div>
        </div>
    </main>
</Layout>

<style>
    #particles-canvas {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        z-index: 1;
    }
</style>

<script>
    import { initParticles } from '../scripts/particles';
    initParticles('particles-canvas', 35);
</script>
